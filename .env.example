# ─── Banco de dados ───────────────────────────────────────
# SQLite (desenvolvimento local)
DATABASE_URL="file:./dev.db"

# PostgreSQL (produção — Neon, Supabase, Railway)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/chronos?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="GERE_UMA_CHAVE_FORTE_AQUI"

# URL base da aplicação
NEXTAUTH_URL="http://localhost:3000"
# Em produção: NEXTAUTH_URL="https://seu-projeto.vercel.app"

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Chronos PM"
NEXT_PUBLIC_APP_VERSION="1.0.0"
